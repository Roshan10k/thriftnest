# Server
PORT=8000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/thriftnest

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
JWT_ACCESS_EXPIRES=15d
JWT_REFRESH_EXPIRES=30d

# Encryption at rest (AES-256-GCM) — 32-byte key as 64 hex chars
# generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-hex-char-32-byte-encryption-key

# Bcrypt
BCRYPT_ROUNDS=12

# TOTP (MFA)
TOTP_SERVICE_NAME=ThriftNest

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@thriftnest.com.np
SMTP_PASS=your-smtp-app-password
EMAIL_FROM="ThriftNest <noreply@thriftnest.com.np>"

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=20
AUTH_LOCKOUT_DURATION_MS=900000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Platform fee (%)
PLATFORM_FEE_PERCENT=5

# Google OAuth 2.0 (create a Web application OAuth client in Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# Stripe (test mode) — from the Stripe Dashboard's test-mode API keys page.
# STRIPE_WEBHOOK_SECRET: run `stripe listen --forward-to localhost:8000/api/payments/webhook`
# locally (Stripe CLI) and use the whsec_... it prints.
STRIPE_SECRET_KEY=sk_test_your-stripe-test-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
